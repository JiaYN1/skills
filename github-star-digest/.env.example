# Required unless NOTIFY_DRY_RUN=true.
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=replace-me

# Optional, but recommended. Unauthenticated GitHub API is enough for Top 50,
# but a token avoids shared-IP rate limits.
GITHUB_TOKEN=

# Local schedule. 09:00 Asia/Shanghai means report yesterday's 00:00-24:00.
TIMEZONE=Asia/Shanghai
RUN_TIME=09:00
RUN_ON_START=false

# Traffic guards. The service downloads GH Archive .json.gz files for the
# target day and aborts before crossing these limits.
ARCHIVE_BASE_URL=https://data.gharchive.org
ARCHIVE_MAX_DOWNLOAD_BYTES=6GiB
ARCHIVE_MONTHLY_DOWNLOAD_BUDGET_BYTES=180GiB

# Ranking controls.
TOP_LIMIT=10
CANDIDATE_LIMIT=50
MIN_UNIQUE_STARGAZERS=5
EXCLUDE_FORKS=true
EXCLUDE_ARCHIVED=true

# Local state and runtime controls.
STATE_FILE=/data/state.json
REQUEST_TIMEOUT=15
LOG_LEVEL=INFO
NOTIFY_DRY_RUN=false
