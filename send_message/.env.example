BILI_UIDS=123456789
POLL_INTERVAL=30
REQUEST_TIMEOUT=12
STATE_FILE=/data/state.json
BILI_COOKIE=

# Choose at least one notification channel.
# WeCom group robot webhook, for example:
# https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
WECHAT_WEBHOOK_URL=

# ServerChan Turbo SendKey, for example: SCTxxxx
SERVERCHAN_SENDKEY=

# First run defaults to recording current dynamics without notifying old content.
NOTIFY_EXISTING_ON_FIRST_RUN=false
MAX_SEEN_PER_UID=500

# Set true to print notifications to logs without sending WeChat messages.
NOTIFY_DRY_RUN=false
LOG_LEVEL=INFO

